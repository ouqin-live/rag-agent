# LLM 接入配置
AI_STUDIO_TOKEN=your_token_here
OPENAI_BASE_URL=https://idealab.alibaba-inc.com/api/openai/v1
OPENAI_MODEL=qwen3.6-plus

# ------------------------------------------------------------------
# 可选配置：留空则使用 rag_agent/config.py 中的默认值
# ------------------------------------------------------------------

# 存储路径
# KB_STORE_PATH=data/kb
# MEMORY_STORE_PATH=data/memory
# EVAL_DB_PATH=data/eval/evaluations.db

# Embedding 模型
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_FALLBACK_DIM=384

# LLM 行为
# LLM_TIMEOUT=60.0
# LLM_TEMPERATURE=0.3
# LLM_MAX_RETRIES=3
# LLM_RETRY_BACKOFF=2.0
# LLM_FALLBACK_MODELS=qwen-turbo
# LLM_HEALTH_FAILURE_THRESHOLD=3

# Agent 行为
# AGENT_TOP_K=5
# AGENT_MAX_TURNS=6

# Agentic RAG（P2-1）
# AGENTIC_ENABLED=false
# AGENTIC_MAX_ITERATIONS=2
# AGENTIC_FAITHFULNESS_THRESHOLD=0.5
# AGENTIC_USE_LLM_ROUTER=false

# MCP 工具（P2-2 扩展）
# MCP_WEB_SEARCH_ENABLED=false
# BRAVE_API_KEY=your_brave_api_key_here
# MCP_SERVER_COMMAND=npx
# MCP_BRAVE_PACKAGE=@modelcontextprotocol/server-brave-search

# 安全护栏（P2-3）
# GUARDRAILS_ENABLED=true
# GUARDRAILS_PROMPT_INJECTION_ENABLED=true
# GUARDRAILS_PROMPT_INJECTION_HARD_BLOCK=false
# GUARDRAILS_PII_ENABLED=true
# GUARDRAILS_PII_HARD_BLOCK=false
# GUARDRAILS_OUTPUT_TOXICITY_ENABLED=true
# GUARDRAILS_OUTPUT_TOXICITY_HARD_BLOCK=false
# GUARDRAILS_CONFIDENCE_ENABLED=true
# GUARDRAILS_CONFIDENCE_THRESHOLD=0.3
# GUARDRAILS_RAISE_ON_BLOCK=false

# 长期记忆策略
# MEMORY_DEDUP_THRESHOLD=0.92
# MEMORY_MERGE_THRESHOLD=0.80
# MEMORY_MAX_FACTS_PER_USER=100

# 评估阈值
# EVAL_FAILURE_THRESHOLD=0.6
# EVAL_ANSWER_MIN_LENGTH=5
# EVAL_ANSWER_MAX_LENGTH=2000

# 调试
# DEBUG=false
# LOG_LEVEL=INFO

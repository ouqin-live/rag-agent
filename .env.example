# LLM 接入配置
AI_STUDIO_TOKEN=your_token_here
OPENAI_BASE_URL=https://idealab.alibaba-inc.com/api/openai/v1
OPENAI_MODEL=qwen3.6-plus

# ------------------------------------------------------------------
# 可选配置：留空则使用 rag_agent/config.py 中的默认值
# ------------------------------------------------------------------

# 存储路径
# KB_STORE_PATH=data/kb
# MEMORY_STORE_PATH=data/memory
# EVAL_DB_PATH=data/eval/evaluations.db

# Embedding 模型
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_FALLBACK_DIM=384

# LLM 行为
# LLM_TIMEOUT=60.0
# LLM_TEMPERATURE=0.3

# Agent 行为
# AGENT_TOP_K=5
# AGENT_MAX_TURNS=6

# 长期记忆策略
# MEMORY_DEDUP_THRESHOLD=0.92
# MEMORY_MERGE_THRESHOLD=0.80
# MEMORY_MAX_FACTS_PER_USER=100

# 评估阈值
# EVAL_FAILURE_THRESHOLD=0.6
# EVAL_ANSWER_MIN_LENGTH=5
# EVAL_ANSWER_MAX_LENGTH=2000

# 调试
# DEBUG=false
# LOG_LEVEL=INFO
# LLM 接入配置
AI_STUDIO_TOKEN=your_token_here
OPENAI_BASE_URL=https://idealab.alibaba-inc.com/api/openai/v1
OPENAI_MODEL=qwen3.6-plus
